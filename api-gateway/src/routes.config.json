{
  "services": {
    "product": {
      "url": "http://localhost:4001",
      "routes": [
        {
          "path": "/api/v1/products",
          "methods": ["post"],
          "middlewares": ["auth"]
        },
        {
          "path": "/api/v1/products",
          "methods": ["get"],
          "middlewares": []
        },
        {
          "path": "/api/v1/products/:id",
          "methods": ["get"],
          "middlewares": []
        }
      ]
    },
    "inventory": {
      "url": "http://localhost:4002",
      "routes": [
        {
          "path": "/api/v1/inventories/:id",
          "methods": ["put"],
          "middlewares": ["auth"]
        },
        {
          "path": "/api/v1/inventories/:id",
          "methods": ["get"],
          "middlewares": ["auth"]
        },
        {
          "path": "/api/v1/inventories/:id/details",
          "methods": ["get"],
          "middlewares": ["auth"]
        }
      ]
    },
    "auth": {
      "url": "http://localhost:4003",
      "routes": [
        {
          "path": "/api/v1/auth/registration",
          "methods": ["post"],
          "middlewares": []
        },
        {
          "path": "/api/v1/auth/login",
          "methods": ["post"],
          "middlewares": []
        },

        {
          "path": "/api/v1/auth/verify-token",
          "methods": ["post"],
          "middlewares": []
        },
        {
          "path": "/api/v1/auth/verify-email",
          "methods": ["post"],
          "middlewares": []
        }
      ]
    },
    "user": {
      "url": "http://localhost:4004",
      "routes": [
        {
          "path": "/api/v1/user/:id",
          "methods": ["get"],
          "middlewares": ["auth"]
        }
      ]
    }
  }
}
