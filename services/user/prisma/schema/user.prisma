model User {
    id         String @id @default(uuid())
    authUserId String @unique
    email      String @unique

    name    String?
    address String?
    phone   String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
    @@index([authUserId])
}

